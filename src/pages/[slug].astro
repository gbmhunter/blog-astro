---
export async function getStaticPaths() {
  const posts = await Astro.glob('../posts/**/*.md')
  console.log("SLUG")
  console.log(posts[0].file)

  // Convert file into slug

  return posts.map(post => ({
    params: { 
      slug: post.frontmatter.slug 
    },
    props: {
      post
    },
  }))
}

const { Content } = Astro.props.post
---
<article>
  <Content/>
</article>